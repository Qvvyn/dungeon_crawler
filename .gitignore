# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.translation

# Exported projects — add platforms as needed
*.apk
*.aab
*.ipa
*.exe
*.x86_64
*.app/

# Web export build output (HTML5 .pck/.wasm/.js artifacts)
walk/
DungeonCrawler.html
DungeonCrawler.pck
DungeonCrawler.wasm
DungeonCrawler.js
DungeonCrawler.audio.worklet.js
DungeonCrawler.audio.position.worklet.js

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Editor metadata (optional: keep if you want to share editor layout)
# .godot/editor/
